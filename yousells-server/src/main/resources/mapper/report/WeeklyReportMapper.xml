<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.yousells.modules.report.mapper.WeeklyReportMapper">

    <resultMap id="WeeklyReportVoMap" type="com.yousells.modules.report.vo.WeeklyReportVo">
        <constructor>
            <idArg column="id" javaType="java.lang.Long"/>
            <arg column="week_key" javaType="java.lang.String"/>
            <arg column="user_name" javaType="java.lang.String"/>
            <arg column="weekly_summary" javaType="java.lang.String"/>
            <arg column="issues" javaType="java.lang.String"/>
            <arg column="next_week_plan" javaType="java.lang.String"/>
        </constructor>
    </resultMap>

    <select id="selectPageWithUser" resultMap="WeeklyReportVoMap">
        SELECT w.id,
               w.week_key,
               u.display_name AS user_name,
               w.weekly_summary,
               w.issues,
               w.next_week_plan
        FROM weekly_reports w
        LEFT JOIN users u ON w.user_id = u.id
        WHERE w.is_deleted = 0
        ORDER BY w.week_key DESC, w.id DESC
    </select>

</mapper>
