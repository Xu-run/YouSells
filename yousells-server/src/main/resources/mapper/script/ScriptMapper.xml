<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.yousells.modules.script.mapper.ScriptMapper">

    <resultMap id="ScriptVoMap" type="com.yousells.modules.script.vo.ScriptVo">
        <constructor>
            <idArg column="id" javaType="java.lang.Long"/>
            <arg column="category_id" javaType="java.lang.Long"/>
            <arg column="category_name" javaType="java.lang.String"/>
            <arg column="title" javaType="java.lang.String"/>
            <arg column="applicable_scene" javaType="java.lang.String"/>
            <arg column="status" javaType="java.lang.String"/>
            <arg column="content" javaType="java.lang.String"/>
            <arg column="updated_at" javaType="java.time.LocalDateTime"/>
        </constructor>
    </resultMap>

    <select id="selectPageWithCategory" resultMap="ScriptVoMap">
        SELECT s.id,
               s.category_id,
               c.category_name,
               s.title,
               s.applicable_scene,
               s.status,
               s.content,
               s.updated_at
        FROM scripts s
        LEFT JOIN script_categories c ON s.category_id = c.id
        WHERE s.is_deleted = 0
        <if test="categoryId != null">
            AND s.category_id = #{categoryId}
        </if>
        <if test="keyword != null and keyword != ''">
            AND (s.title LIKE CONCAT('%', #{keyword}, '%')
                 OR s.content LIKE CONCAT('%', #{keyword}, '%'))
        </if>
        ORDER BY s.updated_at DESC, s.id DESC
    </select>

</mapper>
